<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Minimal activity window theme. All visual theming is handled by the
        Compose CoDriveLogTheme; this exists only to give the window a
        background before Compose draws and to suppress the ActionBar.
        android:Theme.Material.Light.NoActionBar is always available on
        API 21+ (no additional library needed).
    -->
    <style name="Theme.CoDriveLog" parent="android:Theme.Material.Light.NoActionBar" />
</resources>
